# Devvit Configuration
# Copy this file to .env and fill in your values

# Reddit Subreddit Name (for testing)
SUBREDDIT_NAME=italiacareeradvice

# OpenRouter API Key (optional - can be set via menu item)
# Get one at: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-...

# Comment Threshold (default: 75)
COMMENT_THRESHOLD=75

# Devvit Environment
# Values: development, staging, production
DEVVIT_ENV=development

# Log Level
# Values: debug, info, warn, error
LOG_LEVEL=info
